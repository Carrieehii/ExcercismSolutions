class BirdCount
{
    private int[] birdsPerDay;

    public BirdCount(int[] birdsPerDay)
    {
        this.birdsPerDay = birdsPerDay;
    }

    public static int[] LastWeek()
    {
        int [] count; //assign memory for array
        return count = new int [7] {0, 2, 5, 3, 7, 8, 4}; // initialise array with amount and assign elements
    }

    public int Today() => birdsPerDay[6];

    public void IncrementTodaysCount()
    {
     birdsPerDay[6] ++;
    }

    public bool HasDayWithoutBirds()
    {
        foreach (int num in birdsPerDay)
        {
            if (num == 0) return true;            
        }
        return false;
    }

    public int CountForFirstDays(int numberOfDays)
    {
        int result = 0;
        for (int i = 0; i < numberOfDays;i++)
        {
            result += birdsPerDay[i];
        }
        return result;    
    }

    public int BusyDays()
    {
      int busy = 0;
        foreach (int number in birdsPerDay)
        {
            if (number >= 5)
            {
                ++busy;    
            }
        }
        return busy;
    }
}
